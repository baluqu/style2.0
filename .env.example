# StyleBridge - Secure 3D Fashion App Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# CRITICAL SECURITY VARIABLES (REQUIRED IN PRODUCTION)
# ============================================================================

# Secret Key for session management and CSRF protection
# MUST be 32+ random characters in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This is NON-NEGOTIABLE for production - the app will FAIL to start without it
SECRET_KEY=your-strong-random-secret-key-here-32-chars-minimum

# Admin bootstrap key for granting superadmin role
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=your-strong-random-admin-key-32-chars-minimum

# Optional admin account created/updated automatically on startup.
# Use a strong password (12+ chars with mixed case, numbers, symbols)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourStrong#Password123

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL REQUIRED in Production)
# ============================================================================

# Flask Environment: development | production (default: production on Render)
FLASK_ENV=production

# Database URL - SQLite NOT supported in production
# REQUIRED for production: PostgreSQL connection string
# Examples:
#   postgresql://user:password@localhost:5432/stylebridge
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# SSL mode for database connections: require, prefer, disable (default: require in production)
DATABASE_SSL_MODE=require

# Database connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10

# ============================================================================
# HTTPS & SECURITY ENFORCEMENT
# ============================================================================

# HTTPS Enforcement - MUST be true in production
FORCE_HTTPS=true

# Preferred URL scheme
PREFERRED_URL_SCHEME=https

# Session cookie security - MUST be true in production
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
PERMANENT_SESSION_LIFETIME=3600

# Remember-me cookie settings
REMEMBER_COOKIE_SECURE=true
REMEMBER_COOKIE_DURATION=2592000

# Trust X-Forwarded-* headers from a known reverse proxy (Render, Heroku)
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_COUNT=1

# ============================================================================
# FILE UPLOADS
# ============================================================================

# Local upload folder (default: app/static/uploads)
UPLOAD_FOLDER=

# Maximum upload size in MB (default: 8)
MAX_UPLOAD_MB=8

# Recommended for production: Supabase cloud storage
SUPABASE_USE_STORAGE=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=stylebridge-uploads

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: RATE LIMITING
# ============================================================================

# Redis URI for rate limiting backend (for multi-instance deployments)
# Leave empty to use in-memory limiter
# Example: redis://default:<password>@<host>:6379/0
RATELIMIT_STORAGE_URI=

# ============================================================================
# OPTIONAL: OAUTH INTEGRATIONS
# ============================================================================

# Microsoft OAuth
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ============================================================================
# SSL/TLS (Self-signed - for local testing only)
# ============================================================================

# Generate self-signed certs with:
#   openssl req -x509 -newkey rsa:4096 -nodes -out cert.pem -keyout key.pem -days 365
SSL_CERT_FILE=cert.pem
SSL_KEY_FILE=key.pem

