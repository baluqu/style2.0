# StyleBridge - Secure 3D Fashion App Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# === REQUIRED ===

# Secret Key for session management (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-secure-random-key-32-bytes-long

# Admin bootstrap key for granting superadmin role (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_KEY=change-me-to-a-secure-admin-key

# Optional admin account created/updated automatically on startup.
# Use a strong password and keep it only in your local .env.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# === OPTIONAL ===

# Flask Environment: development | production (default: production)
FLASK_ENV=production
LOG_LEVEL=INFO

# Database URL (default: SQLite in instance/app.db)
# Examples:
#   DATABASE_URL=sqlite:///app.db
#   DATABASE_URL=postgresql://user:password@localhost/stylebridge
#   DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   DATABASE_URL=mysql+pymysql://user:password@localhost/stylebridge
DATABASE_URL=
DATABASE_SSL_MODE=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10

# Optional shared rate limit backend for production. Leave empty for the
# default in-memory limiter, or point it at Redis for multi-instance hosting.
# Example: redis://default:<password>@<host>:6379/0
RATELIMIT_STORAGE_URI=

# Upload folder (default: app/static/uploads)
UPLOAD_FOLDER=

# Supabase Storage (recommended for Render production)
# Use a server-side service role key for uploads. The bucket should be public if
# you want the returned URLs to render directly in the UI.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=stylebridge-uploads
SUPABASE_USE_STORAGE=false

# Maximum upload size in MB (default: 8)
MAX_UPLOAD_MB=8

# === SSL/TLS (Production) ===

# Paths to SSL certificate files
# Generate self-signed certs with:
#   openssl req -x509 -newkey rsa:4096 -nodes -out cert.pem -keyout key.pem -days 365
SSL_CERT_FILE=cert.pem
SSL_KEY_FILE=key.pem

# === OAUTH INTEGRATIONS (Optional) ===

# Microsoft OAuth
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# === SECURITY SETTINGS ===

# HTTPS Enforcement (default: True in production, False in development)
FORCE_HTTPS=true

# Trust X-Forwarded-* headers from a known reverse proxy like Render.
# Leave false locally. Set true on Render or other proxy-based hosts.
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_COUNT=1

# Session timeout in seconds (default: 3600 = 1 hour)
PERMANENT_SESSION_LIFETIME=3600

# Remember-me cookie duration in seconds (default: 2592000 = 30 days)
REMEMBER_COOKIE_DURATION=2592000

